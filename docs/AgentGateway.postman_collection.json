{
  "info": {
    "_postman_id": "a1b2c3d4-0001-4a00-9000-agentgatewayadm",
    "name": "AgentGateway",
    "description": "Admin API for AgentGateway. Manage gateways and their registries, policies, consumers and auth credentials. Set the `base_url` and `admin_token` collection variables before running. IDs captured from create responses are stored automatically into `gateway_id`, `registry_id`, `policy_id`, `consumer_id` and `auth_id`. Creating an `api_key` auth returns the generated key exactly once; it is captured into `consumer_api_key` and the proxy plane authenticates with it via the fixed `X-AG-API-Key` header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{admin_token}}", "type": "string" }
    ]
  },
