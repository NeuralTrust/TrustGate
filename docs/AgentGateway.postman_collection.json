    {
      "name": "E2E Flow",
      "description": "End-to-end flow that provisions a gateway with an OpenAI backend, a policy, an API-key credential and a consumer, then sends a real chat-completion through the proxy plane (:8081). Run the requests top-to-bottom (Collection Runner runs them in order). Set the `openai_api_key` variable to a real OpenAI key before running. Step 4 generates the consumer API key server-side and captures it into `consumer_api_key`; step 6 sends it in the fixed `X-AG-API-Key` header (no `X-Gateway-Id` is used).",
      "item": [
        {
          "name": "1. Create Gateway",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('gateway created', () => pm.response.code === 201);",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('gateway_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"e2e-gateway\",\n  \"session_config\": {\n    \"enabled\": true,\n    \"header_name\": \"X-Session-Id\"\n  }\n}"
            },
            "url": { "raw": "{{base_url}}/v1/gateways", "host": ["{{base_url}}"], "path": ["v1", "gateways"] }
          }
        },
        {
          "name": "2. Create Registry (OpenAI)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('registry created', () => pm.response.code === 201);",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('registry_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"openai-primary\",\n  \"provider\": \"openai\",\n  \"description\": \"OpenAI chat completions\",\n  \"weight\": 1,\n  \"provider_options\": {},\n  \"auth\": {\n    \"type\": \"api_key\",\n    \"api_key\": { \"api_key\": \"{{openai_api_key}}\" }\n  }\n}"
            },
            "url": { "raw": "{{base_url}}/v1/gateways/{{gateway_id}}/registries", "host": ["{{base_url}}"], "path": ["v1", "gateways", "{{gateway_id}}", "registries"] }
          }
        },
        {
          "name": "3. Create Policy",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('policy created', () => pm.response.code === 201);",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('policy_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"rate-limit-global\",\n  \"slug\": \"rate_limiter\",\n  \"enabled\": true,\n  \"priority\": 0,\n  \"parallel\": false,\n  \"stages\": [],\n  \"settings\": {\n    \"limits\": {\n      \"global\": { \"limit\": 100, \"window\": \"1m\" }\n    },\n    \"actions\": { \"type\": \"reject\", \"retry_after\": \"60\" }\n  }\n}"
            },
            "url": { "raw": "{{base_url}}/v1/gateways/{{gateway_id}}/policies", "host": ["{{base_url}}"], "path": ["v1", "gateways", "{{gateway_id}}", "policies"] }
          }
        },
        {
          "name": "4. Create Auth API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('auth created', () => pm.response.code === 201);",
                  "pm.test('api key returned once', () => !!pm.response.json().api_key);",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('auth_id', body.id);",
                  "  // The key is generated server-side and only surfaced here; the proxy",
                  "  // step authenticates with it via the fixed X-AG-API-Key header.",
                  "  pm.collectionVariables.set('consumer_api_key', body.api_key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"client-key\",\n  \"type\": \"api_key\",\n  \"enabled\": true\n}"
            },
            "url": { "raw": "{{base_url}}/v1/gateways/{{gateway_id}}/auths", "host": ["{{base_url}}"], "path": ["v1", "gateways", "{{gateway_id}}", "auths"] }
          }
        },
        {
          "name": "5a. Create Consumer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
