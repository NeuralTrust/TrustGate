              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('auth_id', body.id);",
                  "  // The plaintext key is generated server-side and shown ONLY here.",
                  "  if (body.api_key) {",
                  "    pm.collectionVariables.set('consumer_api_key', body.api_key);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
