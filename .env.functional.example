# Functional test environment. Loaded by tests/functional/setup_test.go.
# Values diverge from .env so functional tests can run alongside a dev
# stack without colliding on ports / database / redis db index.

APP_ENV=test

# Distinct ports so a running dev stack does not block the suite.
SERVER_ADMIN_PORT=8090
SERVER_PROXY_PORT=8091
SERVER_READ_TIMEOUT=60s
SERVER_WRITE_TIMEOUT=60s
SERVER_IDLE_TIMEOUT=120s

LOG_LEVEL=WARN
LOG_FORMAT=text

# Dedicated database. Created and dropped by TestMain.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=agentgateway_functional
DB_SSL_MODE=disable
DB_MIN_CONNS=1
DB_MAX_CONNS=4
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_HEALTH_CHECK_PERIOD=1m
DB_CONNECT_TIMEOUT=5s

# Dedicated redis db index.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=9
REDIS_TLS_ENABLED=false
REDIS_TLS_INSECURE_VERIFY=false

CACHE_LOCAL_TTL=5m

# Kafka stays nominally configured; telemetry is disabled so no broker
# is required to boot the admin server.
KAFKA_BROKERS=localhost:9092

TELEMETRY_ENABLED=false
TELEMETRY_KAFKA_TOPIC=agentgateway.requests
TELEMETRY_TRUSTLENS_ENABLED=false
TELEMETRY_TRUSTLENS_URL=

METRICS_ENABLED=false
METRICS_QUEUE_SIZE=1000
METRICS_WORKER_COUNT=1
METRICS_FLUSH_INTERVAL=5s

UPSTREAM_TIMEOUT=60s
UPSTREAM_ERROR_PASSTHROUGH=true

PROVIDER_REQUEST_TIMEOUT=60s
PROVIDER_MAX_RETRIES=2

CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Request-Id
CORS_EXPOSE_HEADERS=X-Request-Id
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=600
