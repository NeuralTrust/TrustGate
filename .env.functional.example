# Functional test environment. Loaded by tests/functional/setup_test.go.
# Values diverge from .env so functional tests can run alongside a dev
# stack without colliding on ports / database / redis db index.

APP_ENV=test

# Distinct ports so a running dev stack does not block the suite.
SERVER_ADMIN_PORT=8090
SERVER_PROXY_PORT=8091
SERVER_MCP_PORT=8092
SERVER_READ_TIMEOUT=60s
SERVER_WRITE_TIMEOUT=60s
SERVER_IDLE_TIMEOUT=120s
# Signs the admin-plane JWT the functional suite mints to call the admin API
# and derives the vault encryption key (>= 32 bytes required by the cipher).
SERVER_SECRET_KEY=functional-test-secret-0123456789abcdef

# Gateway discovery: the suite boots in header mode and covers the subdomain
# fallback against {slug}.llm.neuraltrust.ai hosts.
GATEWAY_DISCOVERY_MODE=header
GATEWAY_BASE_DOMAIN=llm.neuraltrust.ai

LOG_LEVEL=WARN
LOG_FORMAT=text

# Dedicated database. Created and dropped by TestMain.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=trustgate_functional
DB_SSL_MODE=disable
DB_MIN_CONNS=1
DB_MAX_CONNS=4
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_HEALTH_CHECK_PERIOD=1m
DB_CONNECT_TIMEOUT=5s

# Dedicated redis db index.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=9
REDIS_TLS_ENABLED=false
REDIS_TLS_INSECURE_VERIFY=false

CACHE_LOCAL_TTL=5m

# Kafka stays nominally configured. Telemetry is enabled so the metrics pipeline
# (and the playground trace store it drives) runs end-to-end. No broker is
# required to boot: the producer connects lazily and failed publishes are logged,
# not fatal.
KAFKA_BROKERS=localhost:9092

TELEMETRY_ENABLED=true
TELEMETRY_KAFKA_TOPIC=trustgate.requests

METRICS_ENABLED=true
METRICS_QUEUE_SIZE=1000
METRICS_WORKER_COUNT=1
METRICS_FLUSH_INTERVAL=5s

PLAYGROUND_TRACE_STORE_ENABLED=true
PLAYGROUND_TRACE_STORE_TTL=10m

UPSTREAM_TIMEOUT=60s
UPSTREAM_ERROR_PASSTHROUGH=true

PROVIDER_REQUEST_TIMEOUT=60s
PROVIDER_MAX_RETRIES=2

CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-AG-Trace-Id
CORS_EXPOSE_HEADERS=X-AG-Trace-Id
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=600

# TrustGuard plugin (functional stub in plugin_trustguard_test.go).
# setup_test.go also injects these when booting admin/proxy.
TRUSTGUARD_CLIENT_ID=functional-trustguard-client
TRUSTGUARD_CLIENT_SECRET=functional-trustguard-secret
