# Application Environment
APP_ENV=dev

# Server Configuration (HTTP listeners)
SERVER_ADMIN_PORT=8080
SERVER_PROXY_PORT=8081
SERVER_MCP_PORT=8082
SERVER_READ_TIMEOUT=60s
SERVER_WRITE_TIMEOUT=60s
SERVER_IDLE_TIMEOUT=120s
# SERVER_SECRET_KEY signs admin-plane JWTs and derives the vault at-rest
# encryption key (forwarded third-party tokens). Required in production.
SERVER_SECRET_KEY=

# Security Token Service (Phase 4: downstream impersonation/delegation).
# STS_ISSUER is the iss claim of gateway-minted tokens; STS_SIGNING_KEY is an
# RSA private key in PEM (empty = ephemeral dev key, not shared across replicas).
# JWKS is published at {mcp}/.well-known/jwks.json.
STS_ISSUER=trustgate
STS_SIGNING_KEY=

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE_ENABLED=true   # optional local file sink at var/log.log (off in k8s)

# Database Configuration (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=agentgateway
DB_PASSWORD=postgres
DB_NAME=agentgateway
DB_SSL_MODE=disable
DB_SSL_ROOT_CERT=

# Database Connection Pool Configuration (pgxpool)
DB_MIN_CONNS=1
DB_MAX_CONNS=10
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_HEALTH_CHECK_PERIOD=1m
DB_CONNECT_TIMEOUT=5s

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=3
REDIS_TLS_ENABLED=false
REDIS_TLS_INSECURE_VERIFY=false

# In-process TTL cache (app-layer finders).
# RUN-291 will add a parallel Redis-backed layer; same env var stays.
CACHE_LOCAL_TTL=5m

# Kafka Configuration (comma-separated brokers)
KAFKA_BROKERS=localhost:9092

# Telemetry Configuration
TELEMETRY_ENABLED=true
TELEMETRY_KAFKA_TOPIC=agentgateway.requests
TELEMETRY_TRUSTLENS_ENABLED=false
TELEMETRY_TRUSTLENS_URL=

# Metrics Configuration
METRICS_ENABLED=true
METRICS_QUEUE_SIZE=1000
METRICS_WORKER_COUNT=1
METRICS_FLUSH_INTERVAL=5s

# Upstream Forwarding Configuration
UPSTREAM_TIMEOUT=60s
UPSTREAM_ERROR_PASSTHROUGH=true

# Provider Defaults
PROVIDER_REQUEST_TIMEOUT=60s
PROVIDER_MAX_RETRIES=2

# Model/Provider Catalog (admin-only, best-effort sync from OpenRouter on boot)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# CORS Configuration (applied to both admin and proxy servers)
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Request-Id
CORS_EXPOSE_HEADERS=X-Request-Id
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=600
