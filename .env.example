# Application Environment
APP_ENV=dev

# Server Configuration (HTTP listeners)
SERVER_ADMIN_PORT=8080
SERVER_PROXY_PORT=8081
SERVER_READ_TIMEOUT=60s
SERVER_WRITE_TIMEOUT=60s
SERVER_IDLE_TIMEOUT=120s

# Server Secret (REQUIRED, at least 32 bytes of random data)
# Signs and verifies admin-plane and playground JWTs, and derives the AES-256-GCM
# key used to encrypt provider credentials in registries (registries.auth) and
# vault credentials at rest. The process fails to boot if this is shorter than 32
# bytes. Generate one with: openssl rand -base64 32
SERVER_SECRET_KEY=

# Gateway Discovery
# GATEWAY_DISCOVERY_MODE: header (X-AG-Gateway-Slug with host fallback, self-hosted default) | subdomain (host only, cloud)
# GATEWAY_BASE_DOMAIN: suffix to resolve {slug}.<base-domain> proxy hosts (gw.neuraltrust.sandbox for local dev, see make local-dns)
# MCP_BASE_DOMAIN: suffix to resolve {slug}.<base-domain> MCP hosts returned in the gateway response
GATEWAY_DISCOVERY_MODE=header
GATEWAY_BASE_DOMAIN=gw.neuraltrust.sandbox
MCP_BASE_DOMAIN=mcp.neuraltrust.sandbox

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE_ENABLED=true   # optional local file sink at var/log.log (off in k8s)

# Database Configuration (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=agentgateway
DB_PASSWORD=postgres
DB_NAME=agentgateway
DB_SSL_MODE=disable
DB_SSL_ROOT_CERT=

# Database Connection Pool Configuration (pgxpool)
DB_MIN_CONNS=1
DB_MAX_CONNS=10
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_HEALTH_CHECK_PERIOD=1m
DB_CONNECT_TIMEOUT=5s

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=3
REDIS_TLS_ENABLED=false
REDIS_TLS_INSECURE_VERIFY=false

# In-process TTL cache (app-layer finders).
# RUN-291 will add a parallel Redis-backed layer; same env var stays.
CACHE_LOCAL_TTL=5m

# Kafka Configuration (comma-separated brokers)
KAFKA_BROKERS=localhost:9092

# Telemetry Configuration
TELEMETRY_ENABLED=true
TELEMETRY_KAFKA_TOPIC=agentgateway.requests

# OTLP exporter defaults (opt-in per gateway via telemetry.exporters; per-gateway
# settings override these). Timeout is milliseconds per the OTel spec (e.g. 10000);
# a Go duration string (e.g. 10s) is also accepted.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_TIMEOUT=
OTEL_EXPORTER_OTLP_INSECURE=
OTEL_EXPORTER_OTLP_COMPRESSION=

# Metrics Configuration
METRICS_ENABLED=true
METRICS_QUEUE_SIZE=1000
METRICS_WORKER_COUNT=1
METRICS_FLUSH_INTERVAL=5s

# Playground Trace Store Configuration
# Stores the metrics Event of playground requests (those carrying
# X-AG-Playground-Token) in Redis so the dashboard can fetch the trace by its
# X-Request-Id. Enabled by default; disable to turn the integration off.
PLAYGROUND_TRACE_STORE_ENABLED=true
PLAYGROUND_TRACE_STORE_TTL=10m

# Upstream Forwarding Configuration
UPSTREAM_TIMEOUT=60s
UPSTREAM_ERROR_PASSTHROUGH=true

# Provider Defaults
PROVIDER_REQUEST_TIMEOUT=60s
PROVIDER_MAX_RETRIES=2

# Model/Provider Catalog (admin-only, best-effort sync from models.dev on boot)
# Public, key-less source of provider-native model IDs and pricing.
# Override only to point at a mirror; leave empty for https://models.dev
MODELS_DEV_BASE_URL=

# TrustGuard Guardrail Configuration
# Base URL of the external TrustGuard service used by the trustguard plugin.
# Leave empty to keep the plugin inert (pass-through) even if a policy references
# it. Per-policy base_url settings override this value.
TRUSTGUARD_BASE_URL=
TRUSTGUARD_TIMEOUT=15s
# Client-credentials used to obtain a short-lived bearer token from TrustGuard's
# /v1/token endpoint (one credential per gateway deploy). The plugin refuses to
# be configured on a policy unless both are set. For a multi-tenant TrustGate
# deploy use the platform credential; for a per-team deploy use that team's
# credential. The token endpoint is derived from TRUSTGUARD_BASE_URL.
TRUSTGUARD_CLIENT_ID=
TRUSTGUARD_CLIENT_SECRET=

# OpenAI Moderation Guardrail Configuration
# Base URL of the OpenAI Moderations API used by the openai_moderation plugin.
# api_key is configured per-policy in plugin settings, not here.
OPENAI_MODERATION_BASE_URL=https://api.openai.com
OPENAI_MODERATION_TIMEOUT=15s

# Config Sync (ENG-959): gRPC-based snapshot distribution between the admin control
# plane and the DB-less proxy/mcp data planes. The data plane dials the control plane
# (egress-only) over a bidirectional gRPC stream for change notices/acks and pulls the
# compiled snapshot in chunks via GetSnapshot.
# CONFIG_SYNC_DATA_PLANE_ENABLED is the DB-less master flag; leave false to keep the
# proxy/mcp planes on Postgres. When true, DB_* are not required but the CONFIG_SYNC_*
# set below is: token, well-formed CONFIG_SYNC_GRPC_ENDPOINT (host:port), LKG path, a
# base64 key that decodes to exactly 32 bytes (AES-256), and a positive poll interval.
# REDIS_HOST and KAFKA_BROKERS stay required on the data plane. Generate the key with:
# openssl rand -base64 32
CONFIG_SYNC_DATA_PLANE_ENABLED=false
CONFIG_SYNC_TOKEN=
# CONFIG_SYNC_TOKEN_PREVIOUS is the prior bearer accepted alongside CONFIG_SYNC_TOKEN
# during a rotation, so data planes keep authenticating while the new token rolls out.
CONFIG_SYNC_TOKEN_PREVIOUS=
# Control-plane gRPC endpoint (host:port) the data plane dials. Required (well-formed
# host:port) when the flag is ON.
CONFIG_SYNC_GRPC_ENDPOINT=
# Control-plane gRPC listen address (CP). Defaults to :8083.
CONFIG_SYNC_GRPC_LISTEN_ADDR=:8083
# Data-plane dial TLS: optional custom CA bundle path (defaults to the system roots when empty).
CONFIG_SYNC_TLS_CA=
# Data-plane dial TLS: optional SNI/server-name override when it differs from the endpoint host.
CONFIG_SYNC_TLS_SERVER_NAME=
# Data-plane dial TLS: dev-only plaintext dial. Rejected at boot in deployed environments.
CONFIG_SYNC_TLS_INSECURE=false
# Control-plane gRPC server TLS cert/key (PEM paths). Required together on the CP in deployed environments.
CONFIG_SYNC_GRPC_TLS_CERT=
CONFIG_SYNC_GRPC_TLS_KEY=
# Data-plane keepalive tuning that keeps the long-lived Sync stream (and any intermediary NAT/LB) alive.
CONFIG_SYNC_GRPC_KEEPALIVE_TIME=30s
CONFIG_SYNC_GRPC_KEEPALIVE_TIMEOUT=10s
# Data-plane reconnect/watch backoff bounds for the gRPC transport.
CONFIG_SYNC_GRPC_MIN_BACKOFF=1s
CONFIG_SYNC_GRPC_MAX_BACKOFF=30s
CONFIG_SYNC_LKG_PATH=/var/lib/trustgate/snapshot.lkg
CONFIG_SYNC_LKG_KEY=
CONFIG_SYNC_POLL_INTERVAL=5m
CONFIG_SYNC_RECOMPILE_DEBOUNCE=2s
# CONFIG_SYNC_RECOMPILE_BACKSTOP recompiles periodically even without a write
# signal, so the control plane recovers from a failed boot compile and picks up
# out-of-band mutations.
CONFIG_SYNC_RECOMPILE_BACKSTOP=5m
# Control-plane change-marker outbox bounds (safety cap on the pending backlog).
CONFIG_SYNC_OUTBOX_RETENTION=24h
CONFIG_SYNC_OUTBOX_MAX_ROWS=10000
CONFIG_SYNC_INSTANCE_ID=

# CORS Configuration (applied to both admin and proxy servers)
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-AG-Trace-Id
CORS_EXPOSE_HEADERS=X-AG-Trace-Id
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=600
