# Mandatory sensitive data for the DEV overlay.
#
# This is the source blob for the `agentgateway` secret in GCP Secret Manager
# (projects/neuraltrust-app-dev/secrets/agentgateway). It is synced into the
# `agentgateway-secrets` Kubernetes Secret by the CSI SecretProviderClass and
# mounted read-only at /etc/secrets/.env, then loaded at runtime via godotenv.
#
# Copy this file to `secret.env` (gitignored), fill in real values, and upload
# it as a new version of the GCP secret. NEVER commit real secrets.
#   gcloud secrets versions add agentgateway \
#     --project neuraltrust-app-dev --data-file k8s/overlays/dev/secret.env
#
# Non-secret settings (ports, timeouts, TRUSTGUARD_BASE_URL/CLIENT_ID, etc.)
# live in config.env, not here.

# --- Datastores (hosts + credentials) ---
DB_HOST=
DB_PASSWORD=
REDIS_HOST=
REDIS_PASSWORD=

# --- Server secret (REQUIRED, >= 32 bytes) ---
# Signs admin/playground JWTs and derives the AES-256-GCM key for credentials at
# rest. Generate with: openssl rand -base64 32
SERVER_SECRET_KEY=

# --- MCP STS signing key (RSA private key, single-line escaped PEM) ---
# Stable across replicas so all MCP pods share one key. Generate with:
#   openssl genrsa 2048
# then escape newlines: STS_SIGNING_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n
STS_SIGNING_KEY=

# --- TrustGuard client-credentials secret ---
# Pairs with TRUSTGUARD_CLIENT_ID / TRUSTGUARD_BASE_URL in config.env.
TRUSTGUARD_CLIENT_SECRET=

# --- DB-less config sync ---
# Shared bearer token for the snapshot endpoint. Generate with: openssl rand -hex 32
CONFIG_SYNC_TOKEN=
# AES-256 key (base64 that decodes to exactly 32 bytes) for the on-disk LKG cache.
# Generate with: openssl rand -base64 32
CONFIG_SYNC_LKG_KEY=
# HS256 secret that verifies DataCore's per-tenant config-sync JWTs. REQUIRED when
# CONFIG_SYNC_AUTH_MODE=composite (see config.env). Must be byte-for-byte equal to
# DataCore's CONFIG_SYNC_SIGNING_SECRET (datacore secret blob). Auth fails closed if unset.
CONFIG_SYNC_JWT_SECRET=
# Optional prior secret accepted alongside CONFIG_SYNC_JWT_SECRET during rotation.
CONFIG_SYNC_JWT_SECRET_PREVIOUS=
