# Mandatory sensitive data for the PROD-US overlay.
#
# Source blob for the `agentgateway` secret in GCP Secret Manager
# (projects/neuraltrust-prod-us/secrets/agentgateway). Synced into the
# `agentgateway-secrets` Kubernetes Secret by the CSI SecretProviderClass.
#
# Copy to `secret.env` (gitignored), fill real values, upload:
#   gcloud secrets versions add agentgateway \
#     --project neuraltrust-prod-us --data-file k8s/overlays/prod-us/secret.env
#
# NEVER commit real secrets. Do not copy EU prod secret.env.

# --- Datastores (hosts + credentials) ---
# US SaaS Cloud SQL private IP + redis-shared-us (see cloud-infrastructure prod-us)
DB_HOST=
DB_PASSWORD=
REDIS_HOST=
REDIS_PASSWORD=

# --- Server secret (REQUIRED, >= 32 bytes) ---
SERVER_SECRET_KEY=

# --- MCP STS signing key (REQUIRED in prod; RSA private key, single-line escaped PEM) ---
STS_SIGNING_KEY=

# --- TrustGuard client-credentials secret ---
# Pairs with TRUSTGUARD_CLIENT_ID=tgc_platform_prod_us in config.env.
TRUSTGUARD_CLIENT_SECRET=

# --- DB-less config sync ---
CONFIG_SYNC_TOKEN=
CONFIG_SYNC_LKG_KEY=
CONFIG_SYNC_JWT_SECRET=
CONFIG_SYNC_JWT_SECRET_PREVIOUS=
